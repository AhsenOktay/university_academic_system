# ─── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Ana Veritabanı (BAS) ─────────────────────────────────────
DB_NAME=bas_db
DB_USER=bas_user
DB_PASSWORD=bas_password
DB_HOST=db
DB_PORT=5432

# ─── Okul Veritabanı (Senkronizasyon için - Read Only) ────────
SCHOOL_DB_NAME=okul_db
SCHOOL_DB_USER=okul_user
SCHOOL_DB_PASSWORD=okul_password
SCHOOL_DB_HOST=okul_sunucu_ip
SCHOOL_DB_PORT=5432
SCHOOL_DB_SCHEMA=public

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Email ────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=BAS System <noreply@belek.edu.tr>
